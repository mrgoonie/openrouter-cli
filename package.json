{
  "name": "openrouter-cli",
  "version": "0.1.1",
  "description": "OpenRouter CLI — agent + human friendly wrapper for the full OpenRouter API",
  "type": "module",
  "bin": {
    "openrouter": "./bin/openrouter"
  },
  "engines": {
    "bun": ">=1.1.38"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build src/main.ts --compile --minify --outfile bin/openrouter",
    "build:binaries": "bun run scripts/build-binaries.ts",
    "test": "bun test tests/unit",
    "test:integration": "bun --env-file=.env test tests/integration",
    "test:all": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "release": "bun run scripts/release.ts",
    "release:local": "bun run build:binaries"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "1.1.17",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "@clack/prompts": "0.9.1",
    "@napi-rs/keyring": "1.1.6",
    "c12": "2.0.1",
    "citty": "0.1.6",
    "cli-table3": "0.6.5",
    "dotenv": "16.4.7",
    "eventsource-parser": "3.0.0",
    "picocolors": "1.1.1",
    "smol-toml": "1.3.1",
    "zod": "3.24.1"
  },
  "files": ["bin", "dist", "README.md", "LICENSE"],
  "keywords": ["openrouter", "cli", "ai", "llm", "bun"],
  "license": "MIT"
}
