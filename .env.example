# OpenRouter CLI — environment variable template
# Copy to .env and fill in your values. Never commit .env to git.

# Your OpenRouter user API key (required for chat, models, embeddings, etc.)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Your OpenRouter management key (required for credits, keys, guardrails, org, analytics)
# Different from the user API key — generate at https://openrouter.ai/settings/keys
OPENROUTER_MANAGEMENT_KEY=

# Override the API base URL (useful for local mocks or enterprise proxies)
# Default: https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=

# Path to a TOML config file (default: $XDG_CONFIG_HOME/openrouter/config.toml)
OPENROUTER_CONFIG=

# HTTP request timeout in milliseconds (default: 60000)
OPENROUTER_TIMEOUT=60000

# HTTP-Referer header sent with every request (identifies your app to OpenRouter)
OPENROUTER_SITE_URL=https://your-app.example.com

# X-Title header — human-readable name shown in OpenRouter usage dashboard
OPENROUTER_APP_NAME=my-app

# Default output format: pretty | json | ndjson | table | text
# Useful for scripts that always want JSON without --json flag
OPENROUTER_OUTPUT=pretty

# Enable verbose/debug output to stderr (set to 1 to enable)
OPENROUTER_VERBOSE=
